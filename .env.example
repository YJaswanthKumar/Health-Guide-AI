# =============================================================================
# VitalGuide — Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# On Replit, add these as Secrets via the Secrets panel (do NOT commit .env).
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (auto-injected on Replit — do not set manually on Replit)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/vitalguide

# Individual Postgres connection parts (also auto-injected on Replit)
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password
PGDATABASE=vitalguide

# -----------------------------------------------------------------------------
# AUTHENTICATION — Clerk (https://clerk.com)
# Get these from your Clerk dashboard → API Keys
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend receives the publishable key via this alias (set to same value)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk proxy URL — used in production to route Clerk requests through your domain.
# Leave blank for local development.
VITE_CLERK_PROXY_URL=

# -----------------------------------------------------------------------------
# AI — OpenAI (primary — powers all AI chat features: Checkup, Planner, Education)
# Get your key at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative OpenAI key names (used by integrations-openai-ai-server lib)
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# AI — Google Gemini (optional — alternative AI backend)
# If set, the app can be configured to use Gemini 2.5 Flash instead of OpenAI.
# Get your key at: https://aistudio.google.com/apikey (free tier available)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_INTEGRATIONS_GEMINI_API_KEY=
# AI_INTEGRATIONS_GEMINI_BASE_URL=

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Secret string used for session signing — use any long random value
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port for the API server
PORT=8080

# Port for the Vite frontend dev server
# PORT=5000  (set this when starting the frontend)

# URL base path — use "/" for local dev, set to your subpath in production
BASE_PATH=/

# -----------------------------------------------------------------------------
# RUNTIME
# -----------------------------------------------------------------------------
NODE_ENV=development

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
